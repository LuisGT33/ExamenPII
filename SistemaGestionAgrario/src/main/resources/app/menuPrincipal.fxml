<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15.0"
      prefHeight="400.0"
      prefWidth="600.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="app.MenuPrincipalController">

    <children>

        <Label text="SISTEMA GESTIÓN AGRARIA"/>

        <Button text="Parcelas"
                onAction="#abrirParcelas"/>

        <Button text="Cultivos"
                onAction="#abrirCultivos"/>

        <Button text="Responsables"
                onAction="#abrirResponsables"/>

        <Button text="Labores"
                onAction="#abrirLabores"/>

    </children>

</VBox>