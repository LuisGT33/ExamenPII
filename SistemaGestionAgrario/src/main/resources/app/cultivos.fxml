<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.vista.CultivosController">

    <top>

        <VBox spacing="10">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="REGISTRO DE CULTIVOS"/>

            <GridPane hgap="10" vgap="10">

                <Label text="Código:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtCodigo"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Nombre:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtNombre"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Tipo:"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtTipo"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Fecha Siembra:"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtFechaSiembra"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Estado:"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cbEstado"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Guardar"
                        onAction="#guardarCultivo"/>

                <Button text="Eliminar"
                        onAction="#eliminarCultivo"/>

                <Button text="Limpiar"
                        onAction="#limpiarFormulario"/>

            </HBox>

        </VBox>

    </top>

    <center>

        <TableView fx:id="tablaCultivos">

            <columns>

                <TableColumn fx:id="colCodigo" text="Código"/>
                <TableColumn fx:id="colNombre" text="Nombre"/>
                <TableColumn fx:id="colTipo" text="Tipo"/>
                <TableColumn fx:id="colFecha" text="Fecha Siembra"/>
                <TableColumn fx:id="colEstado" text="Estado"/>

            </columns>

        </TableView>

    </center>

</BorderPane>